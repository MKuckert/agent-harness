{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["spotme"],
  "agent": {
    "build": {
      "disable": true,
      "mode": "primary",
    },
    "plan": {
      "disable": true,
      "mode": "primary",
    },
    "general": {
      "disable": true,
      "mode": "subagent",
    },
    "explore": {
      "disable": true,
      "mode": "subagent",
    },

    // System agents
    "compaction": {
      "mode": "primary",
      "hidden": true,
    },
    "title": {
      "mode": "primary",
      "hidden": true,
      "model": "manifest/small",
    },
    "summary": {
      "mode": "primary",
      "hidden": true,
      "model": "manifest/small",
    },
  },
  "mcp": {
    "web": {
      "type": "local",
      "enabled": true,
      "command": ["bin/docker-mcp-gateway-run.sh", "web"],
    },
  },
  "permission": {
    "webfetch": "deny",
    "websearch": "deny",
  },
  "formatter": true,
  "compaction": {
    "auto": true,
    "prune": true,
  },
  // Disables the snapshot feature to roll back agent changes as I'm not using it anyway
  "snapshot": false,
  "experimental": {
    "quotaToast": {
      "enableToast": false,
    },
    "batch_tool": true,
    "disable_paste_summary": true,
    "mcp_timeout": 600000,
  },
}
